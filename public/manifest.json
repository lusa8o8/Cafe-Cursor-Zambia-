{
  "manifest_version": 3,
  "name": "QuickShare - File Transfer",
  "version": "1.0.0",
  "description": "Transfer files between your PC and phone using QR codes or numeric codes",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickShare File Transfer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "/icons/icon-16.png",
    "48": "/icons/icon-48.png",
    "128": "/icons/icon-128.png"
  }
}
